{
  "name": "boardgamebuddy-game-packs",
  "version": "0.0.1",
  "private": true,
  "description": "Community game packs for BoardGameBuddy",
  "workspaces": [
    "api",
    "cli"
  ],
  "scripts": {
    "test": "jest",
    "serve": "node ./serve.js",
    "build": "node -e \"const fs=require('fs'),{execSync}=require('child_process');fs.readdirSync('games').forEach(g=>{const t='games/'+g+'/scorer.ts';if(fs.existsSync(t))execSync('npx esbuild '+t+' --bundle --platform=node --target=es2017 --format=cjs --outfile=games/'+g+'/scorer.js',{stdio:'inherit'})})\"",
    "typecheck": "tsc --project tsconfig.json",
    "watch": "tsc --watch --project tsconfig.json"
  },
  "devDependencies": {
    "@boardgamebuddy/game-pack-api": "*",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "esbuild": "^0.27.3",
    "jest": "^29.0.0",
    "qrcode-terminal": "^0.12.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "playwright": "^1.59.1"
  }
}
